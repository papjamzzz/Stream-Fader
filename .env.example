# Required
TMDB_API_KEY=your_tmdb_key_here          # themoviedb.org/settings/api
MDBLIST_API_KEY=your_mdblist_key         # mdblist.com/preferences/ (Standard plan recommended)

# Recommended
TRAKT_CLIENT_ID=your_trakt_client_id     # trakt.tv/oauth/applications
TRAKT_CLIENT_SECRET=your_trakt_secret

# Optional features
ANTHROPIC_API_KEY=your_anthropic_key     # Claude Top Pick feature
BREVO_API_KEY=your_brevo_api_key         # Email subscriber storage
