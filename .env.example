# Required (get free keys below)
TMDB_API_KEY=your_tmdb_key_here          # themoviedb.org/settings/api
OMDB_API_KEY=your_omdb_key_here          # omdbapi.com/apikey.aspx (free 1k/day)

# Highly recommended (free)
TRAKT_CLIENT_ID=your_trakt_client_id     # trakt.tv/oauth/applications
MDBLIST_API_KEY=your_mdblist_key         # mdblist.com/api (free tier)

# For Claude Top Pick feature
ANTHROPIC_API_KEY=your_anthropic_key
BREVO_API_KEY=your_brevo_api_key
